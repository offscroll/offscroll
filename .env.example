# Copy to .env and fill in your credentials.
# This file is NOT committed to git.

# Mastodon API access token
# Generate at: https://<your-instance>/settings/applications
OFFSCROLL_MASTODON_TOKEN=your-token-here

# Bluesky app password
# Generate at: https://bsky.app/settings/app-passwords
OFFSCROLL_BLUESKY_PASSWORD=your-app-password-here

# SMTP credentials for email digest
OFFSCROLL_SMTP_USER=your-email@example.com
OFFSCROLL_SMTP_PASSWORD=your-smtp-password-here

# Cloud API keys (optional, not needed for default Ollama setup)
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
