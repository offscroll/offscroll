// OffScroll Newspaper — Typst Main Template
// This file is generated by the Python rendering pipeline.
// It sets up the page, imports templates, and assembles the edition.
//
// The Python build_typst_markup() function generates a complete .typ
// file that #imports this template module and calls its functions
// with edition data. This file is the static foundation; the
// generated file is the dynamic content.

#import "templates.typ": *

// --- Page Setup ---
#set page("us-letter",
  margin: 0.5in,
  footer: context {
    if here().page() > 1 {
      set text(7pt, font: "Source Sans 3", fill: luma(153))
      line(length: 100%, stroke: 0.5pt + luma(204))
      v(0.05in)
      // Footer content is injected by the generated file
      // via the page footer-content state
      align(center, state("footer-content", "").get())
    }
  }
)

#set text(10pt, font: "Source Serif 4", fill: luma(26), hyphenate: true)
#set par(justify: true, leading: 0.52em)

